import os
import time

pid = os.fork()

if pid > 0:
    # Parent process
    print(f"Parent exiting. Child PID: {pid}")
    os._exit(0)

# Child process becomes orphan after parent exits
time.sleep(2)

print(f"Orphan process running with PID: {os.getpid()}")
print(f"New parent PID: {os.getppid()}")

# Keep running
while True:
    time.sleep(5)